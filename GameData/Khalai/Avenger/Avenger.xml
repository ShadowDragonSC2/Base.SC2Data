    <CValidatorUnitCompareBehaviorCount id="Avenger_Recall@Cooldown">
        <Behavior value="Avenger_Recall@Cooldown"/>
        <Compare value="LT"/>
        <Value value="1"/>
    </CValidatorUnitCompareBehaviorCount>

