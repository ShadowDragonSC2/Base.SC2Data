    <!-- ========== Weapons ========== -->

    <CWeaponLegacy id="Dragoon_Weapon">
        <EditorCategories value="Race:Protoss"/>
        <Arc value="360"/>
        <DisplayEffect value="Dragoon_Weapon@Damage"/>
        <Effect value="Dragoon_Weapon@LM"/>
        <TargetFilters value="Visible;Missile,Stasis,Dead,Hidden,Invulnerable"/>
        <Range value="7"/>
        <Period value="2"/>
        <Icon value="Assets\Textures\btn-upgrade-protoss-groundweaponslevel0.dds"/>
    </CWeaponLegacy>

    <CActorAction id="Dragoon_Weapon@Attack" parent="GenericAttack" effectLaunch="Dragoon_Weapon@LM" effectImpact="">
        <ImpactMap index="Flesh" ModelReaction="BloodTargetImpact"/>
        <ImpactSiteOps Ops="SOpAttachHarness SOpAttachVolumeStandard SOpForwardLaunchGuide"/>
        <ImpactPhysics Name="DragoonPhaseDisruptorImpact" MatchKeys="Basic" Physics="Dragoon_Weapon@DeathForce"/>
    </CActorAction>
    <CActorMissile id="Dragoon_Weapon@AttackMissile" parent="GenericAttackMissile" unitName="Dragoon_Weapon@AttackMissile">
        <On Terms="UnitBirth" Send="AnimSetTimeScaleAbsolute Lifetime 1.000000"/>
    </CActorMissile>
    <CActorSimple id="Dragoon_Weapon@Animation">
        <On Terms="WeaponStart.Dragoon_Weapon.AttackStart" Send="Create"/>
        <On Terms="WeaponStop.Dragoon_Weapon.AttackStop" Target="_Unit" Send="AnimBracketStop Attack"/>
        <On Terms="ActorCreation" Target="_Unit" Send="AnimBracketStart Attack Cover,Start Cover Cover,End"/>
        <On Terms="WeaponStop.Dragoon_Weapon.AttackStop" Send="Destroy"/>
        <Terms value="Cap 1"/>
    </CActorSimple>
    <CActorForceSphere id="Dragoon_Weapon@DeathForce">
        <Receiver Subject="::Main"/>
        <HostSiteOps Ops="SOpIncomingMissileDot25 SOpRotVariancerForward15"/>
        <Magnitude value="20.000000,5.000000"/>
        <Radius value="0.500000,0.250000"/>
        <Field value="Directional"/>
        <Direction value="Forward"/>
        <Duration value="0.250000"/>
