    <CActorModel id="HHReaper@JumpLandModel" parent="ModelAnimationStyleOneShot">
        <Host Subject="_Selectable"/>
        <HostSiteOps Ops="SOpAttachCenter SOpShadow"/>
        <On Terms="Behavior.HHReaper@Jump.LandDown" Send="Create"/>
