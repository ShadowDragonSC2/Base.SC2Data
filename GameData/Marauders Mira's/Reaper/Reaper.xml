        <On Terms="TimerExpired; TimerName TriggerSound" Send="Create HHReaper@JumpLandSound"/>
        <Inherits index="CloakEffect" value="1"/>
    </CActorModel>
    <CActorModel id="HHReaper@JumpLaunchModel" parent="ModelAnimationStyleOneShot">
