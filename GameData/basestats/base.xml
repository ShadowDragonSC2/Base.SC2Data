    <!-- Behaviors -->

    <CBehaviorBuff default="1" id="Generic_Aura">
        <Period value="0.15"/>
        <PeriodicEffect value="##id##@Aura"/>
        <InfoFlags index="Hidden" value="1"/>
        <BehaviorFlags index="Permanent" value="1"/>
    </CBehaviorBuff>

    <!-- Units -->

    <CUnit default="1" id="Generic_Unit">
        <?token id="race" type="CRaceLink" value="Bogus"?>
        <WeaponArray Link="##id##_Weapon"/>
        
        <Name value="Unit/Name/##id##"/>
        <Description value="Button/Tooltip/##id##"/>
        <GlossaryCategory value="Unit/Category/ProtossFaction/##race##"/>
        <HotkeyCategory value="Unit/Category/ProtossFaction/##race##"/>
        <Race value="##race##"/>
        <LifeArmorName value="Unit/LifeArmorName/##race##Armor"/>
        <ShieldArmorName value="Unit/ShieldArmorName/##race##Armor"/>
        <Acceleration value="1000"/>
        <Mob value="Multiplayer"/>
        <TurningRate value="1000"/>
        <StationaryTurningRate value="1000"/>
        <FlagArray index="ArmySelect" value="1"/>
        <FlagArray index="UseLineOfSight" value="1"/>
        <FlagArray index="PreventDestroy" value="1"/>
        <Speed value="2.25"/>
        <AttackTargetPriority value="20"/>
        <DamageDealtXP value="1"/>
        <DamageTakenXP value="1"/>
        <CostCategory value="Army"/>
        <AbilArray Link="stop"/>
        <AbilArray Link="attack"/>
        <AbilArray Link="move"/>
        <TacticalAIThink value="AIThink##id##"/>
        <CardLayouts>
            <LayoutButtons Face="Move" Type="AbilCmd" AbilCmd="move,Move" Row="0" Column="0"/>
            <LayoutButtons Face="Stop" Type="AbilCmd" AbilCmd="stop,Stop" Row="0" Column="1"/>
            <LayoutButtons Face="MoveHoldPosition" Type="AbilCmd" AbilCmd="move,HoldPos" Row="0" Column="2"/>
            <LayoutButtons Face="Attack" Type="AbilCmd" AbilCmd="attack,Execute" Row="0" Column="4"/>
            <LayoutButtons Face="MovePatrol" Type="AbilCmd" AbilCmd="move,Patrol" Row="0" Column="3"/>
        </CardLayouts>
        <ScoreResult value="BuildOrder"/>
    </CUnit>
    <CUnit default="1" id="Generic_Unit_Ground" parent="Generic_Unit">
        <Collide index="Small" value="1"/>
        <Collide index="Ground" value="1"/>
        <Collide index="ForceField" value="1"/>
        <DeathRevealRadius value="3"/>
        <Name value="Unit/Name/##id##"/>
        <PlaneArray index="Ground" value="1"/>
    </CUnit>
    <CUnit default="1" id="Generic_Unit_Air" parent="Generic_Unit">
        <Name value="Unit/Name/##id##"/>
        <Height value="3.75"/>
        <Sight value="10"/>
        <VisionHeight value="4"/>
        <PlaneArray index="Air" value="1"/>
        <Mover value="Fly"/>
        <Collide index="Flying" value="1"/>
    </CUnit>

    <!-- Validators -->

    <CValidatorUnitType default="1" id="IsUnit_Default">
        <?token id="unit" type="CUnitLink"?>
        <Value value="##unit##"/>
        <WhichUnit Value="Caster"/>
    </CValidatorUnitType>
    <CValidatorUnitType default="1" id="TargetIsUnit_Default" parent="IsUnit_Default">
        <WhichUnit Value="Target"/>
    </CValidatorUnitType>
    <CValidatorUnitType default="1" id="NotUnit_Default" parent="IsUnit_Default">
        <Find value="0"/>
    </CValidatorUnitType>
    <CValidatorUnitType default="1" id="TargetNotUnit_Default" parent="TargetIsUnit_Default">
        <Find value="0"/>
    </CValidatorUnitType>

    <CValidatorUnitState id="IsDetector_Base">
        <State value="Detector"/>
        <Enabled value="1"/>
    </CValidatorUnitState>

    <!-- Sounds -->

    <CSound default="1" id="VO">
        <AssetArray index="0" Speaker="Unit/Name/##Speaker##"/>
    </CSound>
    
</Catalog>