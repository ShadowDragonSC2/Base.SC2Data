    <CDataCollectionPattern id="UpgradeStatsPattern">
        <Fields Reference="Button,^ParamId^,Name"/>
        <Fields Reference="Upgrade,^ParamId^,EffectArrayTemplate[1].Value"/>
        <Fields Reference="Upgrade,^ParamId^,EffectArrayTemplate[2].Value"/>
        <Fields Reference="RequirementNode,^ParamId^Not,EffectArrayTemplate[2].Value"/>
        <Tokens Reference="Upgrade,^ParamId^,icon"/>
    </CDataCollectionPattern>
    <!-- -->
    <CDataCollectionUnit default="1" id="UnitBase">
        <Name value="Unit/Name/##id##"/>
        <Pattern value="UnitPattern_Base"/>
        <UpgradeInfoUnitLifeArmorPerLevel value="1"/>
    </CDataCollectionUnit>
    <CDataCollectionUnit default="1" id="UnitGround" parent="UnitBase">
        <Name value="Unit/Name/##id##"/>
    </CDataCollectionUnit>
    <CDataCollectionUnit default="1" id="UnitAir" parent="UnitBase">
        <Name value="Unit/Name/##id##"/>
        <Pattern value="UnitPattern_Air"/>
    </CDataCollectionUnit>
    
    <CDataCollectionUnit default="1" id="WeaponBase">
        <Name value="Weapon/Name/##id##"/>
        <UpgradeInfoWeapon index="0" DamagePerDice="1"/>
        <Pattern value="WeaponPattern_Base"/>
        <EditorIconSource value="Weapon"/>
    </CDataCollectionUnit>
    <CDataCollectionUnit default="1" id="Weapon_Instant" parent="WeaponBase">
        <Name value="Weapon/Name/##id##"/>
    </CDataCollectionUnit>
    <CDataCollectionUnit default="1" id="Weapon_Missile" parent="WeaponBase">
        <Name value="Weapon/Name/##id##"/>
        <Pattern value="WeaponPattern_Missile"/>
    </CDataCollectionUnit>

    <CDataCollectionUnit default="1" id="AbilityBase">
        <Name value="Abil/Name/##id##"/>
        <Pattern value="AbilityPattern_Base"/>
    </CDataCollectionUnit>

    <CDataCollectionUnit default="1" id="UpgradeBase">
        <Name value="Upgrade/Name/##id##"/>
        <Pattern value="UpgradePattern_Template"/>
        <EditorCategories value="DataGroup:Research,DataFamily:Melee,Race:Protoss,ObjectType:Unit"/>
    </CDataCollectionUnit>
    <CDataCollectionUnit default="1" id="UpgradeStatsBase">
        <Name value="Upgrade/Name/##id##"/>
        <Pattern value="UpgradeStatsPattern"/>
        <EditorCategories value="DataGroup:Research,DataFamily:Melee,Race:Protoss,ObjectType:Unit"/>
    </CDataCollectionUnit>

    <!-- Actors -->
     
    <CActorSplat default="1" id="BurrowedSplat" parent="BurrowedSplatBase">
        <On Terms="UnitBirth.##unitName##@Burrowed" Send="Create"/>
        <On Terms="AbilMorph.*.Start; MorphTo ##unitName##@Burrowed" Send="Create"/>
        <On Terms="AbilMorph.*.Finish; MorphFrom ##unitName##@Burrowed" Send="RefClear ::Host"/>
        <On Terms="AbilMorph.*.Start; MorphFrom ##unitName##@Burrowed" Send="TimerSet 4.000000,2.000000 DelayDestroy"/>
        <On Terms="TimerExpired; TimerName DelayDestroy" Send="Destroy"/>
    </CActorSplat>

    <CActorUnit default="1" id="GenericBurrowerStandard">
        <On Terms="UnitBirth.##unitName##@Burrowed" Send="Create"/>
        <On Terms="UnitBirth.##unitName##@Burrowed" Send="AnimBracketStart Burrow Burrow IGNORE Unburrow ClosingFull,OpeningPlayForever,Instant,DontResetOnUnhide"/>
    </CActorUnit>

    <CActorUnit default="1" id="AdvancedUnitStandard" parent="GenericUnitStandard">
        <ModelFlags index="OutlineEmitter" value="1"/>
        <PortraitModel value="##id##@Portrait"/>
        <BuildModel value="##id##@Build"/>
        <PlacementModel value="##id##@Placement"/>
        <PlacementSound value="##id##@Placement"/>
        
        <On Terms="UnitDeathCustomize; ValidateUnit IsHallucination" Send="DeathCustomize Hallucination"/>

        <DeathCustoms ModelLink="HallucinationDeath" SoundLink="Sentry_HallucinationDeathSmall" Name="Hallucination"/>

        <ModelFlags index="OutlineEmitter" value="1"/>

        <SoundArray index="Attack" value="##unitName##@Attack"/>
        <SoundArray index="Birth" value="##unitName##@Birth"/>
        <SoundArray index="Board" value="##unitName##@Board"/>
        <SoundArray index="Click" value="##unitName##@Click"/>
        <SoundArray index="ClickError" value="##unitName##@ClickError"/>
        <SoundArray index="Construction" value="##unitName##@Construction"/>
        <SoundArray index="Help" value="##unitName##@Help"/>
        <SoundArray index="Highlight" value="##unitName##@Highlight"/>
        <SoundArray index="Movement" value="##unitName##@Movement"/>
        <SoundArray index="Pissed" value="##unitName##@Pissed"/>
        <SoundArray index="Ready" value="##unitName##@Ready"/>
        <SoundArray index="Turning" value="##unitName##@Turning"/>
        <SoundArray index="What" value="##unitName##@What"/>
        <SoundArray index="Yes" value="##unitName##@Yes"/>

        <DeathArray index="Blast" ModelLink="##unitName##@DeathBlast" VoiceLink="##unitName##@BlastDeathVoice" SoundLink="##unitName##@DeathBlast"/>
        <DeathArray index="Cancel" ModelLink="##unitName##@DeathCancel" VoiceLink="##unitName##@CancelDeathVoice" SoundLink="##unitName##@DeathCancel"/>
        <DeathArray index="Disintegrate" ModelLink="##unitName##@DeathDisintegrate" VoiceLink="##unitName##@DisintegrateDeathVoice" SoundLink="##unitName##@DeathDisintegrate"/>
        <DeathArray index="Eat" ModelLink="##unitName##@DeathEat" VoiceLink="##unitName##@EatDeathVoice" SoundLink="##unitName##@DeathEat"/>
