        <DeathArray index="Eviscerate" ModelLink="##unitName##@DeathEviscerate" VoiceLink="##unitName##@EviscerateDeathVoice" SoundLink="##unitName##@DeathEviscerate"/>
        <DeathArray index="Fire" ModelLink="##unitName##@DeathFire" VoiceLink="##unitName##@FireDeathVoice" SoundLink="##unitName##@DeathFire"/>
        <DeathArray index="Freeze" ModelLink="##unitName##@DeathFreeze" VoiceLink="##unitName##@FreezeDeathVoice" SoundLink="##unitName##@DeathFreeze"/>
        <DeathArray index="Impact" ModelLink="##unitName##@DeathImpact" VoiceLink="##unitName##@ImpactDeathVoice" SoundLink="##unitName##@DeathImpact"/>
        <DeathArray index="Morph" ModelLink="##unitName##@DeathMorph" VoiceLink="##unitName##@MorphDeathVoice" SoundLink="##unitName##@DeathMorph"/>
        <DeathArray index="Normal" ModelLink="##unitName##@Death" VoiceLink="##unitName##@DeathVoice" SoundLink="##unitName##@Death"/>
        <DeathArray index="Reincarnation" ModelLink="##unitName##@DeathReincarnation" VoiceLink="##unitName##@ReincarnationDeathVoice" SoundLink="##unitName##@DeathReincarnation"/>
        <DeathArray index="Remove" ModelLink="##unitName##@Remove" VoiceLink="##unitName##@RemoveVoice" SoundLink="##unitName##@Remove"/>
        <DeathArray index="Salvage" ModelLink="##unitName##@Salvage" VoiceLink="##unitName##@SalvageVoice" SoundLink="##unitName##@Salvage"/>
        <DeathArray index="Silentkill" ModelLink="##unitName##@DeathSilentkill" VoiceLink="##unitName##@SilentkillDeathVoice" SoundLink="##unitName##@DeathSilentkill"/>
