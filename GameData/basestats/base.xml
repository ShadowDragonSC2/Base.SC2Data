        <Fields Reference="Weapon,^ParamId^,TargetFilters"/>
        <Fields Reference="Effect,^ParamId^@Damage,Amount"/>
        <Fields Reference="Actor,^ParamId^@Attack,LaunchAttachQuery"/>
        <Fields Reference="Model,^ParamId^@AttackImpact,Model" NameOverride="DataCollectionPattern/NameOverride/Model/Impact"/>
        <Fields Reference="Model,^ParamId^@AttackLaunch,Model" NameOverride="DataCollectionPattern/NameOverride/Model/Launch"/>
        <Fields Reference="Sound,^ParamId^@AttackImpact,AssetArray" NameOverride="DataCollectionPattern/NameOverride/Sound/Impact"/>
        <Fields Reference="Sound,^ParamId^@AttackLaunch,AssetArray" NameOverride="DataCollectionPattern/NameOverride/Sound/Launch"/>
