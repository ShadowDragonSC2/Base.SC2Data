        <Fields Reference="Sound,^ParamId^@What,AssetArray" NameOverride="DataCollectionPattern/NameOverride/Sounds/What"/>
        <Fields Reference="Sound,^ParamId^@Ready,AssetArray" NameOverride="DataCollectionPattern/NameOverride/Sounds/Ready"/>
        <Fields Reference="Requirement,^ParamId^@Use,NodeArray" NameOverride="DataCollectionPattern/NameOverride/Requirement/Use"/>
        <Fields Reference="Requirement,^ParamId^@Show,NodeArray" NameOverride="DataCollectionPattern/NameOverride/Requirement/Show"/>
