    <CDataCollectionPattern id="UpgradePattern_Template">
        <Fields Reference="Button,^ParamId^,Name"/>
        <Fields Reference="Upgrade,^ParamId^@1,EffectArrayTemplate" NameOverride="DataCollectionPattern/NameOverride/UpgradePattern/EffectArrayTemplate/1"/>
        <Fields Reference="Upgrade,^ParamId^@2,EffectArrayTemplate" NameOverride="DataCollectionPattern/NameOverride/UpgradePattern/EffectArrayTemplate/2"/>
        <Fields Reference="Upgrade,^ParamId^@3,EffectArrayTemplate" NameOverride="DataCollectionPattern/NameOverride/UpgradePattern/EffectArrayTemplate/3"/>
        <Fields Reference="Upgrade,^ParamId^@4,EffectArrayTemplate" NameOverride="DataCollectionPattern/NameOverride/UpgradePattern/EffectArrayTemplate/4"/>
        <Fields Reference="Upgrade,^ParamId^@5,EffectArrayTemplate" NameOverride="DataCollectionPattern/NameOverride/UpgradePattern/EffectArrayTemplate/5"/>
        <Fields Reference="Upgrade,^ParamId^@6,EffectArrayTemplate" NameOverride="DataCollectionPattern/NameOverride/UpgradePattern/EffectArrayTemplate/6"/>
        <Fields Reference="Upgrade,^ParamId^@7,EffectArrayTemplate" NameOverride="DataCollectionPattern/NameOverride/UpgradePattern/EffectArrayTemplate/7"/>
        <Fields Reference="Upgrade,^ParamId^@8,EffectArrayTemplate" NameOverride="DataCollectionPattern/NameOverride/UpgradePattern/EffectArrayTemplate/8"/>
        <Fields Reference="Upgrade,^ParamId^@9,EffectArrayTemplate" NameOverride="DataCollectionPattern/NameOverride/UpgradePattern/EffectArrayTemplate/9"/>
