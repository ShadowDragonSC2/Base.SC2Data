    <CDataCollectionPattern id="UnitPattern_Air" parent="UnitPattern_Base">
        <Fields Reference="Unit,^ParamId^,Height" />
        <Fields Reference="Unit,^ParamId^,VisionHeight" />
    </CDataCollectionPattern>

    <CDataCollectionPattern id="WeaponPattern_Base">
        <Fields Reference="Weapon,^ParamId^,Period"/>
        <Fields Reference="Weapon,^ParamId^,Icon"/>
        <Fields Reference="Weapon,^ParamId^,Range"/>
        <Fields Reference="Weapon,^ParamId^,Arc"/>
        <Fields Reference="Weapon,^ParamId^,AllowedMovement"/>
        <Fields Reference="Weapon,^ParamId^,TargetFilters"/>
        <Fields Reference="Effect,^ParamId^@Damage,Amount"/>
        <Fields Reference="Actor,^ParamId^@Attack,LaunchAttachQuery"/>
        <Fields Reference="Model,^ParamId^@AttackImpact,Model" NameOverride="DataCollectionPattern/NameOverride/Model/Impact"/>
        <Fields Reference="Model,^ParamId^@AttackLaunch,Model" NameOverride="DataCollectionPattern/NameOverride/Model/Launch"/>
        <Fields Reference="Sound,^ParamId^@AttackImpact,AssetArray" NameOverride="DataCollectionPattern/NameOverride/Sound/Impact"/>
        <Fields Reference="Sound,^ParamId^@AttackLaunch,AssetArray" NameOverride="DataCollectionPattern/NameOverride/Sound/Launch"/>
        <Fields Reference="DataCollection,^ParamId^,TechInfoUpgradeUsed" NameOverride="DataCollectionPattern/NameOverride/Upgrades"/>
        <Fields Reference="DataCollection,^ParamId^,UpgradeInfoWeapon[0]"/>
        <Fields Reference="DataCollection,^ParamId^,UpgradeInfoWeapon[1]"/>
    </CDataCollectionPattern>
    <CDataCollectionPattern id="WeaponPattern_Missile" parent="WeaponPattern_Base">
        <Fields Reference="Model,^ParamId^@AttackMissile,Model" NameOverride="DataCollectionPattern/NameOverride/Model/Missile"/>
    </CDataCollectionPattern>

    <CDataCollectionPattern id="UpgradePattern_Template">
        <Fields Reference="Button,^ParamId^,Name"/>
        <Fields Reference="Upgrade,^ParamId^@1,EffectArrayTemplate" NameOverride="DataCollectionPattern/NameOverride/UpgradePattern/EffectArrayTemplate/1"/>
        <Fields Reference="Upgrade,^ParamId^@2,EffectArrayTemplate" NameOverride="DataCollectionPattern/NameOverride/UpgradePattern/EffectArrayTemplate/2"/>
        <Fields Reference="Upgrade,^ParamId^@3,EffectArrayTemplate" NameOverride="DataCollectionPattern/NameOverride/UpgradePattern/EffectArrayTemplate/3"/>
        <Fields Reference="Upgrade,^ParamId^@4,EffectArrayTemplate" NameOverride="DataCollectionPattern/NameOverride/UpgradePattern/EffectArrayTemplate/4"/>
        <Fields Reference="Upgrade,^ParamId^@5,EffectArrayTemplate" NameOverride="DataCollectionPattern/NameOverride/UpgradePattern/EffectArrayTemplate/5"/>
        <Fields Reference="Upgrade,^ParamId^@6,EffectArrayTemplate" NameOverride="DataCollectionPattern/NameOverride/UpgradePattern/EffectArrayTemplate/6"/>
        <Fields Reference="Upgrade,^ParamId^@7,EffectArrayTemplate" NameOverride="DataCollectionPattern/NameOverride/UpgradePattern/EffectArrayTemplate/7"/>
        <Fields Reference="Upgrade,^ParamId^@8,EffectArrayTemplate" NameOverride="DataCollectionPattern/NameOverride/UpgradePattern/EffectArrayTemplate/8"/>
        <Fields Reference="Upgrade,^ParamId^@9,EffectArrayTemplate" NameOverride="DataCollectionPattern/NameOverride/UpgradePattern/EffectArrayTemplate/9"/>
        <Fields Reference="Upgrade,^ParamId^@10,EffectArrayTemplate" NameOverride="DataCollectionPattern/NameOverride/UpgradePattern/EffectArrayTemplate/10"/>
    </CDataCollectionPattern>
    <CDataCollectionPattern id="UpgradeStatsPattern">
        <Fields Reference="Button,^ParamId^,Name"/>
        <Fields Reference="Upgrade,^ParamId^,EffectArrayTemplate[1].Value"/>
        <Fields Reference="Upgrade,^ParamId^,EffectArrayTemplate[2].Value"/>
        <Fields Reference="RequirementNode,^ParamId^Not,EffectArrayTemplate[2].Value"/>
        <Tokens Reference="Upgrade,^ParamId^,icon"/>
    </CDataCollectionPattern>
    <!-- -->
    <CDataCollectionUnit default="1" id="UnitBase">
        <Name value="Unit/Name/##id##"/>
        <Pattern value="UnitPattern_Base"/>
        <UpgradeInfoUnitLifeArmorPerLevel value="1"/>
    </CDataCollectionUnit>
    <CDataCollectionUnit default="1" id="UnitGround" parent="UnitBase">
        <Name value="Unit/Name/##id##"/>
    </CDataCollectionUnit>
    <CDataCollectionUnit default="1" id="UnitAir" parent="UnitBase">
        <Name value="Unit/Name/##id##"/>
        <Pattern value="UnitPattern_Air"/>
    </CDataCollectionUnit>
    
    <CDataCollectionUnit default="1" id="WeaponBase">
        <Name value="Weapon/Name/##id##"/>
        <UpgradeInfoWeapon DamagePerDice="0"/>
        <EditorIconSource value="Weapon"/>
    </CDataCollectionUnit>
    <CDataCollectionUnit default="1" id="Weapon_Instant" parent="WeaponBase">
        <Name value="Weapon/Name/##id##"/>
        <Pattern value="WeaponPattern_Base"/>
    </CDataCollectionUnit>
    <CDataCollectionUnit default="1" id="Weapon_Missile" parent="WeaponBase">
        <Name value="Weapon/Name/##id##"/>
        <Pattern value="WeaponPattern_Missile"/>
    </CDataCollectionUnit>

    <CDataCollectionUnit default="1" id="UpgradeBase">
        <Name value="Upgrade/Name/##id##"/>
        <Pattern value="UpgradePattern_Template"/>
        <EditorCategories value="DataGroup:Research,DataFamily:Melee,Race:Protoss,ObjectType:Unit"/>
    </CDataCollectionUnit>
    <CDataCollectionUnit default="1" id="UpgradeStatsBase">
        <Name value="Upgrade/Name/##id##"/>
        <Pattern value="UpgradeStatsPattern"/>
        <EditorCategories value="DataGroup:Research,DataFamily:Melee,Race:Protoss,ObjectType:Unit"/>
    </CDataCollectionUnit>

    <!-- Actors -->
     
    <CActorSplat default="1" id="BurrowedSplat" parent="BurrowedSplatBase">
        <On Terms="UnitBirth.##unitName##@Burrowed" Send="Create"/>
        <On Terms="AbilMorph.*.Start; MorphTo ##unitName##@Burrowed" Send="Create"/>
        <On Terms="AbilMorph.*.Finish; MorphFrom ##unitName##@Burrowed" Send="RefClear ::Host"/>
        <On Terms="AbilMorph.*.Start; MorphFrom ##unitName##@Burrowed" Send="TimerSet 4.000000,2.000000 DelayDestroy"/>
        <On Terms="TimerExpired; TimerName DelayDestroy" Send="Destroy"/>
    </CActorSplat>

    <CActorUnit default="1" id="GenericBurrowerStandard">
        <On Terms="UnitBirth.##unitName##@Burrowed" Send="Create"/>
        <On Terms="UnitBirth.##unitName##@Burrowed" Send="AnimBracketStart Burrow Burrow IGNORE Unburrow ClosingFull,OpeningPlayForever,Instant,DontResetOnUnhide"/>
    </CActorUnit>

    <CActorUnit default="1" id="AdvancedUnitStandard" parent="GenericUnitStandard">
        <PortraitModel value="##id##@Portrait"/>
        <BuildModel value="##id##@Build"/>
        <PlacementModel value="##id##@Placement"/>
        <PlacementSound value="##id##@Placement"/>

        <ModelFlags index="OutlineEmitter" value="1"/>

        <SoundArray index="Attack" value="##unitName##@Attack"/>
        <SoundArray index="Birth" value="##unitName##@Birth"/>
        <SoundArray index="Board" value="##unitName##@Board"/>
        <SoundArray index="Click" value="##unitName##@Click"/>
        <SoundArray index="ClickError" value="##unitName##@ClickError"/>
        <SoundArray index="Construction" value="##unitName##@Construction"/>
        <SoundArray index="Help" value="##unitName##@Help"/>
        <SoundArray index="Highlight" value="##unitName##@Highlight"/>
        <SoundArray index="Movement" value="##unitName##@Movement"/>
        <SoundArray index="Pissed" value="##unitName##@Pissed"/>
        <SoundArray index="Ready" value="##unitName##@Ready"/>
        <SoundArray index="Turning" value="##unitName##@Turning"/>
        <SoundArray index="What" value="##unitName##@What"/>
        <SoundArray index="Yes" value="##unitName##@Yes"/>

        <DeathArray index="Blast" ModelLink="##unitName##@Blast" VoiceLink="##unitName##@BlastVoice" SoundLink="##unitName##@Blast"/>
        <DeathArray index="Cancel" ModelLink="##unitName##@Cancel" VoiceLink="##unitName##@CancelVoice" SoundLink="##unitName##@Cancel"/>
        <DeathArray index="Disintegrate" ModelLink="##unitName##@Disintegrate" VoiceLink="##unitName##@DisintegrateVoice" SoundLink="##unitName##@Disintegrate"/>
        <DeathArray index="Eat" ModelLink="##unitName##@Eat" VoiceLink="##unitName##@EatVoice" SoundLink="##unitName##@Eat"/>
        <DeathArray index="Electrocute" ModelLink="##unitName##@Electrocute" VoiceLink="##unitName##@ElectrocuteVoice" SoundLink="##unitName##@Electrocute"/>
        <DeathArray index="Eviscerate" ModelLink="##unitName##@Eviscerate" VoiceLink="##unitName##@EviscerateVoice" SoundLink="##unitName##@Eviscerate"/>
        <DeathArray index="Fire" ModelLink="##unitName##@Fire" VoiceLink="##unitName##@FireVoice" SoundLink="##unitName##@Fire"/>
        <DeathArray index="Freeze" ModelLink="##unitName##@Freeze" VoiceLink="##unitName##@FreezeVoice" SoundLink="##unitName##@Freeze"/>
        <DeathArray index="Impact" ModelLink="##unitName##@Impact" VoiceLink="##unitName##@ImpactVoice" SoundLink="##unitName##@Impact"/>
        <DeathArray index="Morph" ModelLink="##unitName##@Morph" VoiceLink="##unitName##@MorphVoice" SoundLink="##unitName##@Morph"/>
        <DeathArray index="Normal" ModelLink="##unitName##@Death" VoiceLink="##unitName##@DeathVoice" SoundLink="##unitName##@Death"/>
        <DeathArray index="Reincarnation" ModelLink="##unitName##@Reincarnation" VoiceLink="##unitName##@ReincarnationVoice" SoundLink="##unitName##@Reincarnation"/>
        <DeathArray index="Remove" ModelLink="##unitName##@Remove" VoiceLink="##unitName##@RemoveVoice" SoundLink="##unitName##@Remove"/>
        <DeathArray index="Salvage" ModelLink="##unitName##@Salvage" VoiceLink="##unitName##@SalvageVoice" SoundLink="##unitName##@Salvage"/>
        <DeathArray index="Silentkill" ModelLink="##unitName##@Silentkill" VoiceLink="##unitName##@SilentkillVoice" SoundLink="##unitName##@Silentkill"/>
        <DeathArray index="Squish" ModelLink="##unitName##@Squish" VoiceLink="##unitName##@SquishVoice" SoundLink="##unitName##@Squish"/>
        <DeathArray index="Timeout" ModelLink="##unitName##@Timeout" VoiceLink="##unitName##@TimeoutVoice" SoundLink="##unitName##@Timeout"/>
        <DeathArray index="TrainingCancel" ModelLink="##unitName##@TrainingCancel" VoiceLink="##unitName##@TrainingCancelVoice" SoundLink="##unitName##@TrainingCancel"/>
        <DeathArray index="TrainingComplete" ModelLink="##unitName##@TrainingComplete" VoiceLink="##unitName##@TrainingCompleteVoice" SoundLink="##unitName##@TrainingComplete"/>
        <DeathArray index="UnderConstruction" ModelLink="##unitName##@UnderConstruction" VoiceLink="##unitName##@UnderConstruction" SoundLink="##unitName##@UnderConstruction"/>
        <DeathArray index="Unknown" ModelLink="##unitName##@Unknown" VoiceLink="##unitName##@UnknownVoice" SoundLink="##unitName##@Unknown"/>
    </CActorUnit>

    <CActorUnit default="1" id="AdvancedStandard_Ground" parent="AdvancedUnitStandard">
        <Macros value="UnloadDropAnim"/>
        <Macros value="PhysicsDeathsSwarmGround"/>
        <Macros value="PhysicsDeathsVoidGround"/>
        <WalkAnimMoveSpeed value="2.25"/>
    </CActorUnit>

    <!-- Buttons -->

    <CButton default="1" id="Button_AppenderIndent">
        <TooltipAppender Face="##id##" Text="Button/Tooltip/Appender/Indent"/>
    </CButton>
    <CButton default="1" id="UnitButton_OnlyGround" parent="Button_AppenderIndent">
        <TooltipAppender Text="Button/Tooltip/Appender/OnlyGround"/>
    </CButton>
    <CButton default="1" id="UnitButton_OnlyAir" parent="Button_AppenderIndent">
        <TooltipAppender Text="Button/Tooltip/Appender/OnlyAir"/>
    </CButton>
    <CButton default="1" id="UnitButton_GroundAir" parent="Button_AppenderIndent">
        <TooltipAppender Text="Button/Tooltip/Appender/GroundAir"/>
    </CButton>
    <CButton default="1" id="UnitButton_Detector" parent="Button_AppenderIndent">
        <TooltipAppender Text="Button/Tooltip/Appender/Detector"/>
    </CButton>
    <CButton default="1" id="UnitButton_OnlyGroundDetector" parent="UnitButton_OnlyGround">
        <TooltipAppender Text="Button/Tooltip/Appender/Detector"/>
    </CButton>
    <CButton default="1" id="UnitButton_OnlyAirDetector" parent="UnitButton_OnlyAir">
        <TooltipAppender Text="Button/Tooltip/Appender/Detector"/>
    </CButton>
    <CButton default="1" id="UnitButton_GroundAirDetector" parent="UnitButton_GroundAir">
        <TooltipAppender Text="Button/Tooltip/Appender/Detector"/>
    </CButton>

    <!-- Units -->

    <CUnit default="1" id="Generic_Unit">
        <Name value="Unit/Name/##id##"/>
        <Description value="Button/Tooltip/##id##"/>
        <Acceleration value="1000"/>
        <Mob value="Multiplayer"/>
        <FlagArray index="ArmySelect" value="1"/>
        <FlagArray index="UseLineOfSight" value="1"/>
        <FlagArray index="PreventDestroy" value="1"/>
        <Speed value="2.25"/>
        <AttackTargetPriority value="20"/>
        <DamageDealtXP value="1"/>
        <DamageTakenXP value="1"/>
        <CostCategory value="Army"/>
        <AbilArray Link="stop"/>
        <AbilArray Link="attack"/>
        <AbilArray Link="move"/>
        <TacticalAIThink value="AIThink##id##"/>
        <GlossaryAlias value="##id##"/>
        <CardLayouts>
            <LayoutButtons Face="Move" Type="AbilCmd" AbilCmd="move,Move" Row="0" Column="0"/>
            <LayoutButtons Face="Stop" Type="AbilCmd" AbilCmd="stop,Stop" Row="0" Column="1"/>
            <LayoutButtons Face="MoveHoldPosition" Type="AbilCmd" AbilCmd="move,HoldPos" Row="0" Column="2"/>
            <LayoutButtons Face="Attack" Type="AbilCmd" AbilCmd="attack,Execute" Row="0" Column="4"/>
            <LayoutButtons Face="MovePatrol" Type="AbilCmd" AbilCmd="move,Patrol" Row="0" Column="3"/>
        </CardLayouts>
        <ScoreResult value="BuildOrder"/>
    </CUnit>
    <CUnit default="1" id="Generic_Unit_Ground" parent="Generic_Unit">
        <Collide index="Small" value="1"/>
        <Collide index="Ground" value="1"/>
        <Collide index="ForceField" value="1"/>
        <DeathRevealRadius value="3"/>
        <Name value="Unit/Name/##id##"/>
        <PlaneArray index="Ground" value="1"/>
    </CUnit>
    <CUnit default="1" id="Generic_Unit_Air" parent="Generic_Unit">
        <Name value="Unit/Name/##id##"/>
        <Height value="3.75"/>
        <Sight value="10"/>
        <VisionHeight value="4"/>
        <PlaneArray index="Air" value="1"/>
        <Mover value="Fly"/>
        <Collide index="Flying" value="1"/>
    </CUnit>

    <!-- Validators -->

    <CValidatorUnitType default="1" id="IsUnit_Default">
        <?token id="unit" type="CUnitLink"?>
        <Value value="##unit##"/>
        <WhichUnit Value="Caster"/>
    </CValidatorUnitType>
    <CValidatorUnitType default="1" id="TargetIsUnit_Default" parent="IsUnit_Default">
        <WhichUnit Value="Target"/>
    </CValidatorUnitType>
    <CValidatorUnitType default="1" id="NotUnit_Default" parent="IsUnit_Default">
        <Find value="0"/>
    </CValidatorUnitType>
    <CValidatorUnitType default="1" id="TargetNotUnit_Default" parent="TargetIsUnit_Default">
        <Find value="0"/>
    </CValidatorUnitType>

    <!-- Sounds -->

    <CSound default="1" id="VO">
        <AssetArray index="0" Speaker="Unit/Name/##Speaker##"/>
    </CSound>
    
</Catalog>