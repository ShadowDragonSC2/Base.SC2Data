        <Fields Reference="Unit,^ParamId^,EnergyMax"/>
        <Fields Reference="Unit,^ParamId^,EnergyArmor"/>
        <Fields Reference="Unit,^ParamId^,Sight"/>
        <Fields Reference="Unit,^ParamId^,Speed"/>
        <Fields Reference="Unit,^ParamId^,Food"/>
