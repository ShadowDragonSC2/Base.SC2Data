<?xml version="1.0" encoding="UTF-8"?>
<Catalog>
    <CUnit default="1" id="Generic_Protoss_Unit" parent="Generic_Unit">
        <Name value="Unit/Name/##id##"/>
        <Description value="Button/Tooltip/##id##"/>
        <ShieldRegenDelay value="10"/>
        <ShieldRegenRate value="2"/>
        <AbilArray Link="Warpable"/>
        <AbilArray Link="ProgressRally"/>
        <CardLayouts index="0">
            <LayoutButtons Face="Rally" Type="AbilCmd" AbilCmd="ProgressRally,Rally1" Row="2" Column="4"/>
        </CardLayouts>
    </CUnit>
    <CUnit default="1" id="Generic_Protoss_Unit_Ground" parent="Generic_Protoss_Unit">
        <Name value="Unit/Name/##id##"/>
        <Collide index="Small" value="1"/>
        <Collide index="Ground" value="1"/>
        <Collide index="ForceField" value="1"/>
        <PlaneArray index="Ground" value="1"/>
    </CUnit>
    <CUnit default="1" id="Generic_Protoss_Unit_Air" parent="Generic_Protoss_Unit">
        <Name value="Unit/Name/##id##"/>
        <Height value="3.75"/>
        <Sight value="10"/>
        <VisionHeight value="4"/>
        <PlaneArray index="Air" value="1"/>
        <Mover value="Fly"/>
        <Collide index="Flying" value="1"/>
    </CUnit>

    <!-- Actors -->
    <CActorProgress id="ProtossConstruction">
        <On Terms="Abil.TaldarimProbe_Build.BuildStart" Send="Create"/>
    </CActorProgress>

    <CActorUnit default="1" id="ProtossCollection@Building" parent="AdvancedUnitStandard">
        <Macros value="BuildingFlattenTerrainMacro"/>
        <Macros value="SnowVisualBuildingMacroMP"/>
        <BuildModel value="##unitName##@Birth"/>
        <ModelFlags index="OutlineOccluder" value="1"/>
        <Aliases value="_CreepEngulfable"/>
        <CreepHeightClass value="Medium"/>
        <CreepRateGrow value="Grow"/>
        <CreepRateShrink value="Shrink"/>
        <On Terms="UnitDeathCustomize; CreepEngulfs" Send="CreepEngulfmentStopTransition"/>
        <On Terms="ActorCreation; CreepIntersects" Send="CreepEngulfmentStartTransition"/>
        <On Terms="UnitConstruction.##unitName##.Start" Send="Create ##unitName##@Build"/>
        <EventDataSound Name="BuildingWarpIn" Actor="UnitSound" Sound="Protoss_BuildingWarpIn"/>
        <PlacementSound value="Protoss_BuildingPlacement"/>
        <SoundArray index="Construction" value="Protoss_ConstructionWhat"/>
    </CActorUnit>

    <CDataCollection id="ProtossCollection">
        <DataRecord Entry="Actor,ProtossCollection@Building"/>
    </CDataCollection>

    <!-- Upgrades -->

    <CUpgrade default="1" id="ProtossArmors">
        <?token id="icon" type="CImagePath" value="Bogus"?>
        <Icon value="##icon##"/>
        <EffectArrayTemplate Operation="Set" Reference="Actor,^ParamId^,LifeArmorIcon" Value="{Upgrade,##id##,Icon}"/>
        <EffectArrayTemplate Reference="Unit,^ParamId^,LifeArmor" Value="{DataCollection,^ParamId^,UpgradeInfoUnitLifeArmorPerLevel}"/>
        <EffectArrayTemplate Reference="Unit,^ParamId^,LifeArmorLevel" Value="1"/>
    </CUpgrade>

    <CUpgrade default="1" id="ProtossWeapons">
        <?token id="icon" type="CImagePath" value="Bogus"?>
        <Icon value="##icon##"/>
        <EffectArrayTemplate Operation="Set" Reference="Weapon,^ParamId^,Icon" Value="{Upgrade,##id##,Icon}"/>
        <EffectArrayTemplate Reference="Effect,^ParamId^@Damage,Amount" Value="{DataCollection,^ParamId^,UpgradeInfoWeapon[0].DamagePerDice}"/>
        <EffectArrayTemplate Reference="Weapon,^ParamId^,Level" Value="1"/>
    </CUpgrade>

    <CUpgrade default="1" id="ProtossArmorShield">
        <?token id="icon" type="CImagePath" value="Bogus"?>
        <Icon value="##icon##"/>
        <EffectArrayTemplate Operation="Set" Reference="Actor,^ParamId^,ShieldArmorIcon" Value="{Upgrade,##id##,Icon}"/>
        <EffectArrayTemplate Reference="Unit,^ParamId^,ShieldArmor" Value="{DataCollection,^ParamId^,UpgradeInfoUnitLifeArmorPerLevel}"/>
        <EffectArrayTemplate Reference="Unit,^ParamId^,ShieldArmorLevel" Value="1"/>
        <EffectArrayTemplate Reference="Unit,^ParamId^,ShieldRegenRate" Value="2"/>
    </CUpgrade>

