    <!-- Upgrades -->
    <!-- Protoss Air Armors -->
    <CButton id="ProtossAirArmors">
        <Icon value="Assets\Textures\btn-upgrade-protoss-airarmorlevel1.dds"/>
    </CButton>

    <CUpgrade default="1" id="ProtossAirArmors@0">
        <EffectArrayTemplate Reference="Unit,^ParamId^,LifeArmor" Value="{DataCollection,^ParamId^,UpgradeInfoUnitLifeArmorPerLevel}"/>
        <EffectArrayTemplate Reference="Unit,^ParamId^,LifeArmorLevel" Value="1"/>
    </CUpgrade>
    <CUpgrade id="ProtossAirArmors@1" parent="ProtossAirArmors@0">
        <Icon value="Assets\Textures\btn-upgrade-protoss-airarmorlevel1.dds"/>
