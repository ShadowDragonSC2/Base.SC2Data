    <CActorAction id="Energizer_Weapon@Attack" parent="GenericAttack" effectLaunch="Energizer_Weapon@Beam" effectImpact="Energizer_Weapon@Damage">
        <ImpactSiteOps Ops="SOpAttachHarness SOpAttachVolumeNoVizEnhance SOpForwardLaunchGuide"/>
        <AcquisitionYawHalfArc value="10.000000"/>
        <ActionFlags index="AlignedImpactsAndDamages" value="1"/>
        <ActionFlags index="ImpactMonitorsTeleports" value="1"/>
        <!-- Need this so the impact host ops can know which side of the target is closest to 
             the attacker. -->
        <ActionFlags index="LaunchForceSite" value="1"/>
        <Lifetime value="-1.000000"/>
    </CActorAction>
    <CActorBeamSimple id="Energizer_Weapon@AttackBeam" parent="BeamSimpleAnimationStyleContinuous">
        <On Terms="Effect.Energizer_Weapon@Beam.Stop; At Effect" Send="AnimBracketStop BSD"/>
        <On Terms="ActorCreation" Send="RefSetFromRequest ::actor.CasterUnit _Unit Caster Find"/>
        <Macros value="ActionTargetTeleportDestroy"/>
    </CActorBeamSimple>
    
    <CActorSound id="Energizer_Weapon@Loop" parent="SoundContinuous">
        <On Terms="Effect.Energizer_Weapon@Beam.Start" Send="Create"/>
        <On Terms="Effect.Energizer_Weapon@Beam.Stop" Send="Destroy"/>
    </CActorSound>
